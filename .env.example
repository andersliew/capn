# Neon pooled Postgres URL (server-only). Required on Vercel too — same value as in Neon dashboard.
DATABASE_URL=

# Random string for signing session cookies — required on Vercel/production (login will 503 without it).
CAPN_SESSION_SECRET=

# Shared dashboard password for @capnapp.com accounts (override default in production).
# CAPN_DASHBOARD_PASSWORD=

# --- Optional: production Gmail sync on dashboard load (workflow_dispatch) ---
# PAT needs permission to dispatch workflows on this repo (fine-grained: Actions read + write).
# GITHUB_SYNC_TOKEN=
# GITHUB_SYNC_REPO=owner/repo
# GITHUB_SYNC_WORKFLOW_FILE=gmail-sync.yml
# GITHUB_SYNC_REF=main

# Optional: shared secret for non-browser callers (header x-gmail-sync-secret).
# GMAIL_SYNC_TRIGGER_SECRET=
